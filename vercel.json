{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!assets|favicon).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "frame-ancestors https://*.myshopify.com https://admin.shopify.com" },
        { "key": "X-Frame-Options", "value": "ALLOWALL" }
      ]
    }
  ],
  "functions": {
    "api/generate.js": { "maxDuration": 30 },
    "api/generate-images.js": { "maxDuration": 60 },
    "api/publish.js": { "maxDuration": 60 },
    "api/auth.js": { "maxDuration": 30 },
    "api/auth/callback.js": { "maxDuration": 30 }
  }
}
